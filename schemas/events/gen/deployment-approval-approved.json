{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
        "#ApprovalEventData": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "comment": {
                    "type": "string"
                },
                "decidedBy": {
                    "type": "string"
                },
                "decision": {
                    "enum": [
                        "approved",
                        "rejected"
                    ]
                },
                "message": {
                    "type": "string"
                },
                "status": {
                    "$ref": "#/$defs/%23DeploymentStatus"
                }
            },
            "required": [
                "message"
            ]
        },
        "#DeploymentStatus": {
            "enum": [
                "Pending",
                "Running",
                "Complete",
                "Failed",
                "Deleting",
                "Deleted",
                "Cancelled",
                "AwaitingApproval"
            ]
        }
    },
    "type": "object",
    "additionalProperties": true,
    "properties": {
        "decision": {
            "const": "approved"
        },
        "status": {
            "const": "Running"
        }
    },
    "$ref": "#/$defs/%23ApprovalEventData"
}
