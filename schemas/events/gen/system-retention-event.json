{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true,
    "properties": {
        "deploymentKey": {
            "type": "string"
        },
        "deploymentsPruned": {
            "allOf": [
                {
                    "type": "number"
                },
                {
                    "type": "integer",
                    "minimum": 0
                }
            ]
        },
        "deploymentsScanned": {
            "allOf": [
                {
                    "type": "number"
                },
                {
                    "type": "integer",
                    "minimum": 0
                }
            ]
        },
        "error": {
            "type": "string"
        },
        "failedDeployments": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "indexEntriesPruned": {
            "allOf": [
                {
                    "type": "number"
                },
                {
                    "type": "integer",
                    "minimum": 0
                }
            ]
        },
        "maxAge": {
            "type": "string"
        },
        "message": {
            "type": "string"
        },
        "prunedChunks": {
            "allOf": [
                {
                    "type": "number"
                },
                {
                    "type": "integer",
                    "minimum": 0
                }
            ]
        },
        "prunedEvents": {
            "allOf": [
                {
                    "type": "number"
                },
                {
                    "type": "integer",
                    "minimum": 0
                }
            ]
        },
        "shippedEvents": {
            "allOf": [
                {
                    "type": "number"
                },
                {
                    "type": "integer",
                    "minimum": 0
                }
            ]
        },
        "workspace": {
            "type": "string"
        }
    },
    "required": [
        "message"
    ]
}
