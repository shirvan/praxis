---
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---

<footer>
  <div class="footer-inner">
    <div>
      <strong>Praxis</strong>
      <p>A durable AWS infrastructure control plane powered by CUE and Restate.</p>
    </div>
    <div class="footer-links">
      <a href={`${base}docs/`}>Documentation</a>
      <a href={`${base}resources/`}>Resources</a>
      <a href="https://github.com/shirvan/praxis/blob/main/LICENSE">Apache 2.0 license</a>
      <a href="https://github.com/shirvan/praxis">GitHub</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--line);
    padding: 42px 24px 54px;
    color: var(--ink-subtle);
  }

  .footer-inner {
    max-width: var(--max);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 32px;
  }

  strong {
    color: var(--ink);
  }

  p {
    max-width: 520px;
    margin: 7px 0 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
  }

  .footer-links a {
    color: var(--ink-subtle);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--ink);
  }

  @media (max-width: 680px) {
    .footer-inner {
      flex-direction: column;
    }
  }
</style>
