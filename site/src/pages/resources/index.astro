---
import ProductNav from '../../components/ProductNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { domains, resources } from '../../data/resources';

const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const lookupCount = resources.filter((resource) => resource.lookup).length;
---

<SiteLayout title="AWS resources | Praxis" description="Browse the AWS resource kinds currently managed by Praxis.">
  <ProductNav />
  <main>
    <header class="catalog-hero">
      <div class="shell">
        <p class="eyebrow">AWS resource catalog</p>
        <h1>One lifecycle across 51 resource kinds.</h1>
        <p>Every driver uses the same generic provision, import, delete, observe, lookup, and reconcile contract. Browse human-readable schemas and examples by service or infrastructure domain.</p>
        <div class="catalog-meta"><span><b>{resources.length}</b> resources</span><span><b>{new Set(resources.map((r) => r.service)).size}</b> AWS services</span><span><b>{lookupCount}</b> read-only lookups</span></div>
      </div>
    </header>

    <section class="catalog shell">
      <div class="filters" role="group" aria-label="Filter resources by domain">
        {domains.map((domain, index) => <button type="button" class:list={{ active: index === 0 }} data-domain={domain}>{domain}</button>)}
      </div>
      <div class="catalog-tools">
        <label class="search"><span>Search resources</span><input id="resource-search" type="search" placeholder="VPC, Lambda, DynamoDB…" autocomplete="off" /></label>
        <div class="view-switcher" role="group" aria-label="Resource display">
          <span>View</span>
          <button type="button" data-view="grid" aria-pressed="true"><i class="grid-icon" aria-hidden="true"></i>Cards</button>
          <button type="button" data-view="list" aria-pressed="false"><i class="list-icon" aria-hidden="true"></i>List</button>
        </div>
      </div>

      <div class="resource-grid" id="resource-grid">
        {resources.map((resource) => (
          <a class="resource-card" href={`${base}resources/${resource.slug}/`} data-domain={resource.domain} data-search={`${resource.kind} ${resource.service} ${resource.description}`.toLowerCase()}>
            <div class="card-top"><span>{resource.service}</span><em>{resource.scope}</em></div>
            <h2>{resource.kind}</h2>
            <p>{resource.description}</p>
            <div class="capabilities"><span>Schema</span><span>Examples</span>{resource.lookup && <span class="lookup">Lookup</span>}</div>
          </a>
        ))}
      </div>
      <p class="empty" id="empty-state" hidden>No resources match that filter.</p>
    </section>
  </main>
  <SiteFooter />
</SiteLayout>

<script>
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-domain]'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.resource-card'));
  const search = document.querySelector<HTMLInputElement>('#resource-search');
  const empty = document.querySelector<HTMLElement>('#empty-state');
  const grid = document.querySelector<HTMLElement>('#resource-grid');
  const viewButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-view]'));
  let activeDomain = 'All';

  function filterCards() {
    const query = search?.value.trim().toLowerCase() ?? '';
    let visible = 0;
    cards.forEach((card) => {
      const domainMatches = activeDomain === 'All' || card.dataset.domain === activeDomain;
      const searchMatches = !query || card.dataset.search?.includes(query);
      card.hidden = !(domainMatches && searchMatches);
      if (!card.hidden) visible += 1;
    });
    if (empty) empty.hidden = visible !== 0;
  }

  buttons.forEach((button) => button.addEventListener('click', () => {
    activeDomain = button.dataset.domain ?? 'All';
    buttons.forEach((candidate) => candidate.classList.toggle('active', candidate === button));
    filterCards();
  }));
  search?.addEventListener('input', filterCards);

  function setView(view: string) {
    const nextView = view === 'list' ? 'list' : 'grid';
    if (grid) grid.dataset.view = nextView;
    viewButtons.forEach((button) => button.setAttribute('aria-pressed', String(button.dataset.view === nextView)));
    localStorage.setItem('praxis-resource-view', nextView);
  }

  viewButtons.forEach((button) => button.addEventListener('click', () => setView(button.dataset.view ?? 'grid')));
  setView(localStorage.getItem('praxis-resource-view') ?? 'grid');
</script>

<style>
  .shell { width: min(var(--max), calc(100% - 48px)); margin: 0 auto; }
  .catalog-hero { padding: 92px 0 64px; border-bottom: 1px solid var(--line); background: radial-gradient(circle at 78% 0%, var(--hero-glow), transparent 36%); }
  .eyebrow { margin: 0 0 16px; color: var(--blue-bright); font: 650 .76rem/1.4 "SFMono-Regular", Consolas, monospace; letter-spacing: .095em; text-transform: uppercase; }
  h1 { max-width: 820px; margin: 0; font-size: clamp(2.8rem, 6vw, 5.4rem); line-height: 1; letter-spacing: -.06em; }
  .catalog-hero p:not(.eyebrow) { max-width: 720px; margin: 24px 0 0; color: var(--ink-subtle); font-size: 1.08rem; line-height: 1.7; }
  .catalog-meta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 32px; }
  .catalog-meta span { border: 1px solid var(--line); border-radius: 999px; padding: 7px 12px; color: var(--ink-subtle); font-size: .78rem; }
  .catalog-meta b { color: var(--ink); }
  .catalog { padding-block: 46px 94px; }
  .filters { display: flex; flex-wrap: wrap; gap: 8px; }
  .filters button { border: 1px solid var(--line); border-radius: 999px; padding: 8px 13px; background: var(--surface-raised); color: var(--ink-subtle); cursor: pointer; font: 600 .78rem/1 system-ui, sans-serif; }
  .filters button:hover, .filters button.active { border-color: var(--blue); color: var(--ink); background: var(--blue-soft); }
  .catalog-tools { display: flex; align-items: end; justify-content: space-between; gap: 24px; margin: 30px 0 24px; }
  .search { display: block; flex: 1; }
  .search span { display: block; margin-bottom: 8px; color: var(--ink-subtle); font-size: .76rem; font-weight: 650; text-transform: uppercase; letter-spacing: .06em; }
  .search input { width: min(100%, 520px); min-height: 46px; border: 1px solid var(--line); border-radius: 9px; padding: 0 14px; background: var(--surface-raised); color: var(--ink); font: inherit; outline: none; }
  .search input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px color-mix(in srgb, var(--blue) 14%, transparent); }
  .resource-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .resource-card { min-height: 224px; display: flex; flex-direction: column; border: 1px solid var(--line); border-radius: 11px; padding: 22px; background: var(--surface-raised); color: var(--ink); text-decoration: none; transition: transform .15s ease, border-color .15s ease; }
  .resource-card:hover { transform: translateY(-2px); border-color: var(--line-strong); }
  .resource-card[hidden] { display: none; }
  .card-top { display: flex; justify-content: space-between; gap: 12px; color: var(--blue-bright); font: 600 .68rem/1.3 "SFMono-Regular", Consolas, monospace; text-transform: uppercase; letter-spacing: .055em; }
  .card-top em { color: var(--ink-muted); font-style: normal; }
  h2 { margin: 25px 0 0; font-size: 1.12rem; letter-spacing: -.02em; }
  .resource-card p { flex: 1; margin: 9px 0 20px; color: var(--ink-subtle); font-size: .84rem; line-height: 1.58; }
  .capabilities { display: flex; flex-wrap: wrap; gap: 6px; }
  .capabilities span { border: 1px solid var(--line); border-radius: 5px; padding: 4px 7px; color: var(--ink-muted); font: .62rem/1.2 "SFMono-Regular", Consolas, monospace; }
  .capabilities .lookup { border-color: color-mix(in srgb, var(--green) 45%, var(--line)); color: var(--green); background: var(--green-soft); }
  .view-switcher { display: flex; align-items: center; gap: 7px; }
  .view-switcher > span { margin-right: 2px; color: var(--ink-subtle); font-size: .76rem; font-weight: 650; text-transform: uppercase; letter-spacing: .06em; }
  .view-switcher button { min-height: 38px; display: inline-flex; align-items: center; gap: 7px; border: 1px solid var(--line); border-radius: 8px; padding: 0 11px; background: var(--surface-raised); color: var(--ink-subtle); cursor: pointer; font: 600 .76rem/1 system-ui, sans-serif; }
  .view-switcher button[aria-pressed='true'] { border-color: var(--blue); background: var(--blue-soft); color: var(--ink); }
  .grid-icon { width: 12px; height: 12px; background: linear-gradient(currentColor 0 0) 0 0/5px 5px, linear-gradient(currentColor 0 0) 100% 0/5px 5px, linear-gradient(currentColor 0 0) 0 100%/5px 5px, linear-gradient(currentColor 0 0) 100% 100%/5px 5px; background-repeat: no-repeat; }
  .list-icon { width: 13px; height: 11px; border-block: 2px solid currentColor; position: relative; }
  .list-icon::after { content: ''; position: absolute; inset: 3px 0; border-top: 2px solid currentColor; }
  .resource-grid[data-view='list'] { grid-template-columns: 1fr; gap: 8px; }
  .resource-grid[data-view='list'] .resource-card { min-height: 0; display: grid; grid-template-columns: minmax(150px, .55fr) minmax(150px, .55fr) minmax(260px, 1.45fr) auto; align-items: center; gap: 22px; padding: 17px 20px; }
  .resource-grid[data-view='list'] .resource-card:hover { transform: translateX(2px); }
  .resource-grid[data-view='list'] .card-top { display: grid; gap: 5px; }
  .resource-grid[data-view='list'] h2 { margin: 0; }
  .resource-grid[data-view='list'] .resource-card p { margin: 0; }
  .resource-grid[data-view='list'] .capabilities { justify-content: flex-end; }
  .empty { border: 1px dashed var(--line); border-radius: 10px; padding: 40px; color: var(--ink-subtle); text-align: center; }
  @media (max-width: 900px) { .resource-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 900px) { .resource-grid[data-view='list'] .resource-card { grid-template-columns: 150px 1fr auto; } .resource-grid[data-view='list'] .resource-card p { display: none; } }
  @media (max-width: 620px) { .shell { width: min(var(--max), calc(100% - 32px)); } .catalog-hero { padding-top: 68px; } .catalog-tools { align-items: stretch; flex-direction: column; } .view-switcher { justify-content: flex-end; } .resource-grid { grid-template-columns: 1fr; } .resource-grid[data-view='list'] .resource-card { grid-template-columns: 1fr auto; gap: 12px; } .resource-grid[data-view='list'] .card-top { grid-column: 1 / -1; } }
</style>
