---
import ProductNav from '../components/ProductNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteLayout from '../layouts/SiteLayout.astro';

const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---

<SiteLayout
  title="Praxis | Durable AWS infrastructure control plane"
  description="Declare AWS infrastructure in CUE, preview changes, deploy durably, import existing resources, and continuously reconcile drift without Kubernetes."
>
  <ProductNav />

  <main>
    <section class="hero">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="shell hero-grid">
        <div class="hero-copy">
          <p class="eyebrow"><span></span> Desired state for AWS</p>
          <h1>Your AWS infrastructure, continuously converged.</h1>
          <p class="hero-lead">
            Declare resources in CUE. Preview changes, deploy with durable execution, import what
            already exists, and keep desired and actual state aligned without Kubernetes.
          </p>
          <div class="actions">
            <a class="button primary" href={`${base}docs/start/first-deployment/`}>Deploy your first stack</a>
            <a class="button secondary" href={`${base}resources/`}>Explore 51 resources</a>
          </div>
          <div class="trust-row" aria-label="Praxis foundations">
            <span>CUE schemas</span>
            <span>Restate execution</span>
            <span>AWS APIs</span>
            <span>CLI + HTTP</span>
          </div>
        </div>

        <div class="terminal-window" aria-label="Example Praxis CLI session">
          <div class="panel-top">
            <div class="window-dots" aria-hidden="true"><i></i><i></i><i></i></div>
            <span>praxis · ~/infrastructure</span>
            <span class="terminal-badge">CLI</span>
          </div>
          <div class="terminal-body">
            <div class="command-line">
              <span class="prompt">$</span>
              <code>praxis plan stack.cue -f dev.vars.json \<br />&nbsp;&nbsp;--account local --out web-dev.plan.json</code>
            </div>
            <div class="plan-output" aria-label="Plan output">
              <span><b>+</b> VPC <em>web-dev-vpc</em></span>
              <span><b>+</b> SecurityGroup <em>web-dev-sg</em></span>
              <span><b>+</b> EC2Instance <em>web-dev</em></span>
            </div>
            <p class="plan-summary">Plan: <b>3 to create</b>, 0 to update, 0 to delete, 0 unchanged.</p>
            <p class="saved-plan"><span>Saved plan</span> web-dev.plan.json</p>

            <div class="command-line deploy-command">
              <span class="prompt">$</span>
              <code>praxis deploy --plan web-dev.plan.json \<br />&nbsp;&nbsp;--key web-dev --wait</code>
            </div>
            <div class="deployment-output">
              <p><span>Deployment</span> web-dev</p>
              <p><span>Status</span> <b>Complete</b></p>
              <div class="terminal-table" aria-label="Deployment resources">
                <span class="table-head">RESOURCE</span><span class="table-head">KIND</span><span class="table-head">STATUS</span>
                <span>vpc</span><span>VPC</span><b>Ready</b>
                <span>webSG</span><span>SecurityGroup</span><b>Ready</b>
                <span>server</span><span>EC2Instance</span><b>Ready</b>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="proof">
      <div class="shell proof-grid">
        <div><strong>51</strong><span>AWS resource kinds</span></div>
        <div><strong>1</strong><span>uniform driver lifecycle</span></div>
        <div><strong>0</strong><span>Kubernetes clusters required</span></div>
        <div><strong>24/7</strong><span>desired-state awareness</span></div>
      </div>
    </section>

    <section class="workflow" id="product">
      <div class="shell">
        <div class="section-heading">
          <p class="eyebrow">Declare through reconcile</p>
          <h2>Use one resource model for every stage.</h2>
          <p>Praxis owns the path from declaration to durable operation. The same desired state drives planning, provisioning, observation, and reconciliation.</p>
        </div>

        <div class="workflow-grid">
          <article class="code-window">
            <div class="code-title"><span>stack.cue</span><small>CUE</small></div>
            <pre><code><span class="comment">// Typed, validated infrastructure</span>
resources: &#123;
  network: vpc.#VPC & &#123;
    metadata: &#123;name: <span class="string">"payments"</span>, labels: &#123;&#125;&#125;
    spec: &#123;
      region: <span class="string">"us-west-2"</span>
      cidrBlock: <span class="string">"10.42.0.0/16"</span>
      tags: environment: <span class="string">"prod"</span>
    &#125;
  &#125;

  database: rds.#RDSInstance & &#123;
    metadata: &#123;name: <span class="string">"payments-db"</span>, labels: &#123;&#125;&#125;
    spec: subnetGroupName:
      <span class="string">"$&#123;resources.dbSubnets.outputs.name&#125;"</span>
  &#125;
&#125;</code></pre>
          </article>

          <div class="lifecycle-list">
            <article>
              <span class="step">01</span>
              <div><h3>Validate and plan</h3><p>CUE catches invalid inputs before cloud calls. Praxis builds the dependency graph and shows the exact resource plan.</p></div>
            </article>
            <article>
              <span class="step">02</span>
              <div><h3>Execute durably</h3><p>Restate journals workflow progress, serializes each resource, and resumes work safely after process or network failures.</p></div>
            </article>
            <article>
              <span class="step">03</span>
              <div><h3>Observe continuously</h3><p>Drivers compare the declared state with AWS. Conditions and events keep drift visible, even when correction is disabled.</p></div>
            </article>
            <article>
              <span class="step">04</span>
              <div><h3>Converge deliberately</h3><p>Managed resources return to the user’s desired state. Observed resources stay green while clearly reporting external drift.</p></div>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="capabilities">
      <div class="shell">
        <div class="section-heading compact">
          <p class="eyebrow">Core capabilities</p>
          <h2>Plan, operate, and inspect the same desired state.</h2>
        </div>
        <div class="capability-grid">
          <article><span>01</span><h3>Typed CUE templates</h3><p>Compose schemas, constraints, defaults, variables, and cross-resource outputs in one declarative language.</p><a href={`${base}docs/build/templates/`}>Build a template →</a></article>
          <article><span>02</span><h3>Dependency-aware deployment</h3><p>Praxis resolves a resource DAG, hydrates outputs at dispatch time, and runs independent work concurrently.</p><a href={`${base}docs/understand/architecture/`}>See the execution model →</a></article>
          <article><span>03</span><h3>Plan and apply</h3><p>Preview changes, save plans for review, target a subgraph, and protect resources from replacement or deletion.</p><a href={`${base}docs/operate/plan-deploy/`}>Plan a deployment →</a></article>
          <article><span>04</span><h3>Import and observe</h3><p>Bring existing AWS resources under managed or visibility-only control without recreating them.</p><a href={`${base}docs/operate/import/`}>Import infrastructure →</a></article>
          <article><span>05</span><h3>Drift and conditions</h3><p>Continuously compare reality with intent, surface what changed, and correct it according to lifecycle policy.</p><a href={`${base}docs/operate/reconciliation/`}>Understand reconciliation →</a></article>
          <article><span>06</span><h3>CLI and HTTP API</h3><p>Use the same operations from an interactive terminal, automation, or an agent. Every command can return JSON.</p><a href={`${base}docs/reference/cli/`}>Explore the interface →</a></article>
        </div>
      </div>
    </section>

    <section class="execution">
      <div class="shell execution-grid">
        <div>
          <p class="eyebrow">Durable by construction</p>
          <h2>Failures pause work. They do not erase progress.</h2>
          <p>Praxis models each managed resource as a Restate Virtual Object. Resource mutations are serialized, workflow steps are journaled, and retries preserve the operation’s history.</p>
          <a class="text-link" href={`${base}docs/understand/durable-execution/`}>How durable execution changes infrastructure automation →</a>
        </div>
        <div class="execution-flow" aria-label="Praxis request flow">
          <div><small>Intent</small><strong>CUE template</strong></div>
          <span>→</span>
          <div><small>Control</small><strong>Praxis Core</strong></div>
          <span>→</span>
          <div class="active"><small>Runtime</small><strong>Restate</strong></div>
          <span>→</span>
          <div><small>Reality</small><strong>AWS APIs</strong></div>
        </div>
      </div>
    </section>

    <section class="resources-preview">
      <div class="shell">
        <div class="resource-heading">
          <div><p class="eyebrow">AWS resource coverage</p><h2>Model complete AWS stacks with 51 resource kinds.</h2></div>
          <a class="button secondary" href={`${base}resources/`}>Browse all resources</a>
        </div>
        <div class="domain-grid">
          <article><b>Networking</b><span>VPC, Subnet, Security Group, NAT Gateway, Route Table, ALB, NLB</span></article>
          <article><b>Compute</b><span>EC2, AMI, EBS, ECS, EKS, Lambda, layers and event sources</span></article>
          <article><b>Data</b><span>S3, DynamoDB, RDS, Aurora, SQS, SNS and Secrets Manager</span></article>
          <article><b>Identity</b><span>IAM roles, policies, users, groups, instance profiles and KMS keys</span></article>
          <article><b>Operations</b><span>CloudWatch dashboards, alarms, logs, Route 53 and ACM certificates</span></article>
        </div>
      </div>
    </section>

    <section class="closing">
      <div class="shell closing-card">
        <div><p class="eyebrow">Start with an inspectable plan</p><h2>Declare a stack. Review the change. Keep it converged.</h2></div>
        <div class="actions"><a class="button primary" href={`${base}docs/start/first-deployment/`}>Read the quickstart</a><a class="button secondary" href="https://github.com/shirvan/praxis">View the source</a></div>
      </div>
    </section>
  </main>

  <SiteFooter />
</SiteLayout>

<style>
  .shell { width: min(var(--max), calc(100% - 48px)); margin: 0 auto; }
  .hero { position: relative; overflow: hidden; padding: 104px 0 86px; }
  .hero::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(var(--grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--grid-line) 1px, transparent 1px); background-size: 48px 48px; mask-image: linear-gradient(to bottom, black, transparent 82%); pointer-events: none; }
  .hero-glow { position: absolute; width: 760px; height: 620px; right: -120px; top: -180px; background: radial-gradient(circle, var(--hero-glow), transparent 68%); pointer-events: none; }
  .hero-grid { position: relative; display: grid; grid-template-columns: 1.04fr .96fr; gap: 72px; align-items: center; }
  .eyebrow { margin: 0 0 18px; color: var(--blue-bright); font: 650 .76rem/1.4 "SFMono-Regular", Consolas, monospace; letter-spacing: .095em; text-transform: uppercase; }
  .hero .eyebrow span { display: inline-block; width: 24px; height: 1px; margin-right: 8px; vertical-align: middle; background: var(--blue); }
  h1 { max-width: 720px; margin: 0; font-size: clamp(3.25rem, 6.8vw, 6.15rem); line-height: .98; letter-spacing: -.066em; font-weight: 730; }
  .hero-lead { max-width: 675px; margin: 30px 0 0; color: var(--ink-subtle); font-size: clamp(1.06rem, 1.7vw, 1.26rem); line-height: 1.65; }
  .actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 34px; }
  .button { display: inline-flex; min-height: 46px; align-items: center; justify-content: center; border-radius: 9px; padding: 0 18px; font-size: .91rem; font-weight: 670; text-decoration: none; transition: border-color .15s ease, background .15s ease, transform .15s ease; }
  .button:hover { transform: translateY(-1px); }
  .primary { background: var(--blue); color: #fff; }
  .primary:hover { background: color-mix(in srgb, var(--blue) 84%, var(--ink)); }
  .secondary { border: 1px solid var(--line); background: color-mix(in srgb, var(--surface-raised) 72%, transparent); color: var(--ink); }
  .secondary:hover { border-color: var(--line-strong); background: var(--surface-raised); }
  .trust-row { display: flex; flex-wrap: wrap; gap: 10px 22px; margin-top: 42px; color: var(--ink-muted); font: 600 .72rem/1.4 "SFMono-Regular", Consolas, monospace; text-transform: uppercase; letter-spacing: .06em; }
  .terminal-window { border: 1px solid var(--code-line); border-radius: 14px; overflow: hidden; background: var(--code-surface); color: var(--code-ink); box-shadow: 0 32px 90px var(--shadow), inset 0 1px rgba(255,255,255,.035); transform: perspective(1100px) rotateY(-3deg) rotateX(1deg); }
  .panel-top { min-height: 45px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 0 14px; border-bottom: 1px solid var(--code-line); color: #9aa6b8; font: 600 .7rem/1 "SFMono-Regular", Consolas, monospace; }
  .window-dots { display: flex; gap: 6px; }
  .window-dots i { width: 8px; height: 8px; border-radius: 50%; background: #364258; }
  .terminal-badge { justify-self: end; border: 1px solid #364258; border-radius: 5px; padding: 4px 6px; color: #8794a8; font-size: .58rem; letter-spacing: .08em; }
  .terminal-body { padding: 22px 22px 24px; font: .7rem/1.6 "SFMono-Regular", Consolas, monospace; }
  .command-line { display: grid; grid-template-columns: 14px minmax(0, 1fr); gap: 8px; color: #dbe3ee; }
  .command-line code { color: inherit; font: inherit; overflow-wrap: anywhere; }
  .prompt { color: var(--blue-bright); font-weight: 700; }
  .plan-output { display: grid; gap: 4px; margin: 17px 0 0 22px; color: #aab5c4; }
  .plan-output span { display: grid; grid-template-columns: 18px minmax(105px, auto) 1fr; gap: 7px; }
  .plan-output b { color: var(--green); }
  .plan-output em { color: #7f8da2; font-style: normal; }
  .plan-summary { margin: 16px 0 0 22px; color: #aab5c4; }
  .plan-summary b { color: var(--green); font-weight: 600; }
  .saved-plan { margin: 5px 0 0 22px; color: #dbe3ee; }
  .saved-plan span, .deployment-output span { display: inline-block; width: 88px; color: #758298; }
  .deploy-command { margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--code-line); }
  .deployment-output { margin: 15px 0 0 22px; color: #dbe3ee; }
  .deployment-output p { margin: 3px 0; }
  .deployment-output > p > b { color: var(--green); font-weight: 600; }
  .terminal-table { display: grid; grid-template-columns: .75fr 1.25fr .65fr; column-gap: 12px; row-gap: 3px; margin-top: 13px; padding-top: 10px; border-top: 1px solid var(--code-line); color: #aab5c4; }
  .terminal-table .table-head { width: auto; color: #68768b; font-size: .61rem; }
  .terminal-table b { color: var(--green); font-weight: 600; }
  .proof { border-block: 1px solid var(--line); background: var(--surface-alt); }
  .proof-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .proof-grid div { padding: 28px 24px; border-left: 1px solid var(--line); }
  .proof-grid div:last-child { border-right: 1px solid var(--line); }
  .proof-grid strong { display: block; font: 670 1.7rem/1 "SFMono-Regular", Consolas, monospace; }
  .proof-grid span { display: block; margin-top: 8px; color: var(--ink-subtle); font-size: .82rem; }
  section:not(.hero):not(.proof) { padding: 108px 0; }
  .section-heading { max-width: 790px; margin-bottom: 54px; }
  .section-heading.compact { margin-bottom: 38px; }
  h2 { margin: 0; font-size: clamp(2.1rem, 4vw, 3.45rem); line-height: 1.08; letter-spacing: -.045em; }
  .section-heading > p:last-child, .execution-grid > div > p:not(.eyebrow) { max-width: 680px; margin: 20px 0 0; color: var(--ink-subtle); font-size: 1.04rem; line-height: 1.7; }
  .workflow-grid { display: grid; grid-template-columns: 1.02fr .98fr; gap: 62px; align-items: start; }
  .code-window { position: sticky; top: 92px; border: 1px solid var(--code-line); border-radius: 12px; overflow: hidden; background: var(--code-surface); box-shadow: 0 28px 70px var(--shadow); }
  .code-title { min-height: 44px; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; border-bottom: 1px solid var(--code-line); color: #aab5c4; font: .72rem/1 "SFMono-Regular", Consolas, monospace; }
  .code-title small { color: var(--blue-bright); }
  pre { margin: 0; padding: 24px; overflow: auto; color: var(--code-ink); font-size: .78rem; line-height: 1.75; }
  .comment { color: #68768b; }
  .string { color: #9dd9bd; }
  .lifecycle-list article { display: grid; grid-template-columns: 52px 1fr; gap: 20px; padding: 25px 0; border-top: 1px solid var(--line); }
  .lifecycle-list article:last-child { border-bottom: 1px solid var(--line); }
  .step { width: 38px; height: 38px; display: grid; place-items: center; border: 1px solid color-mix(in srgb, var(--blue) 55%, var(--line)); border-radius: 8px; background: var(--blue-soft); color: var(--blue-bright); font: .7rem/1 "SFMono-Regular", Consolas, monospace; }
  h3 { margin: 0; font-size: 1.05rem; }
  .lifecycle-list p, .capability-grid p { margin: 8px 0 0; color: var(--ink-subtle); line-height: 1.65; font-size: .91rem; }
  .capabilities { border-top: 1px solid var(--line); background: var(--surface-alt); }
  .capability-grid { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .capability-grid article { min-height: 260px; padding: 28px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--surface-raised) 72%, transparent); }
  .capability-grid article > span { color: var(--ink-muted); font: .7rem/1 "SFMono-Regular", Consolas, monospace; }
  .capability-grid h3 { margin-top: 30px; font-size: 1.13rem; }
  .capability-grid a, .text-link { display: inline-block; margin-top: 22px; color: var(--blue-bright); font-size: .84rem; font-weight: 620; text-decoration: none; }
  .execution { border-top: 1px solid var(--line); }
  .execution-grid { display: grid; grid-template-columns: .78fr 1.22fr; gap: 70px; align-items: center; }
  .execution-flow { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr; gap: 10px; align-items: center; }
  .execution-flow div { min-height: 112px; display: flex; flex-direction: column; justify-content: center; border: 1px solid var(--line); border-radius: 10px; padding: 14px; background: var(--surface-raised); }
  .execution-flow div.active { border-color: var(--blue); background: var(--blue-soft); box-shadow: 0 0 44px color-mix(in srgb, var(--blue) 14%, transparent); }
  .execution-flow small { color: var(--ink-muted); font: .64rem/1.2 "SFMono-Regular", Consolas, monospace; text-transform: uppercase; }
  .execution-flow strong { margin-top: 8px; font-size: .82rem; }
  .execution-flow > span { color: var(--ink-muted); }
  .resources-preview { border-top: 1px solid var(--line); background: var(--surface-alt); }
  .resource-heading { display: flex; justify-content: space-between; gap: 32px; align-items: end; margin-bottom: 42px; }
  .resource-heading .button { flex: 0 0 auto; }
  .domain-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
  .domain-grid article { min-height: 176px; border: 1px solid var(--line); border-radius: 10px; padding: 22px; background: var(--surface-raised); }
  .domain-grid b { display: block; margin-bottom: 15px; color: var(--blue-bright); font-size: .9rem; }
  .domain-grid span { color: var(--ink-subtle); font-size: .81rem; line-height: 1.65; }
  .closing { border-top: 1px solid var(--line); }
  .closing-card { display: flex; justify-content: space-between; gap: 42px; align-items: center; border: 1px solid color-mix(in srgb, var(--blue) 45%, var(--line)); border-radius: 16px; padding: 52px; background: radial-gradient(circle at 80% 20%, var(--hero-glow), transparent 44%), var(--surface-raised); }
  .closing-card h2 { max-width: 660px; font-size: clamp(2rem, 3.5vw, 3rem); }
  .closing-card .actions { flex: 0 0 auto; margin: 0; }
  @media (max-width: 1000px) {
    .hero-grid, .workflow-grid, .execution-grid { grid-template-columns: 1fr; }
    .hero { padding-top: 78px; }
    .terminal-window { max-width: 700px; transform: none; }
    .code-window { position: static; }
    .domain-grid { grid-template-columns: repeat(3, 1fr); }
    .closing-card { align-items: flex-start; flex-direction: column; }
  }
  @media (max-width: 720px) {
    .shell { width: min(var(--max), calc(100% - 32px)); }
    .hero { padding: 62px 0; }
    h1 { font-size: clamp(3rem, 14vw, 4.4rem); }
    .proof-grid { grid-template-columns: repeat(2, 1fr); }
    .proof-grid div { border-bottom: 1px solid var(--line); }
    section:not(.hero):not(.proof) { padding: 76px 0; }
    .capability-grid { grid-template-columns: 1fr; }
    .execution-flow { grid-template-columns: 1fr; }
    .execution-flow > span { transform: rotate(90deg); justify-self: center; }
    .domain-grid { grid-template-columns: 1fr; }
    .resource-heading { align-items: flex-start; flex-direction: column; }
    .closing-card { padding: 30px 24px; }
    .closing-card .actions { width: 100%; }
    .closing-card .button { width: 100%; }
  }
</style>
