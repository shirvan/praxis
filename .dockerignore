# Keep secrets and build artifacts out of the Docker build context.
# The Dockerfile does `COPY . .`, so anything not listed here ends up in the
# builder stage. `.env` matches the root env file exactly; .env.example is
# still included.
.git
.env
bin/
dist/
# None of these directories are inputs to the Go service binaries or the
# schema bundle copied into praxis-core. Keeping them out avoids invalidating
# image caches for website, documentation, test, and packaging-only changes.
.github/
charts/
deploy/
docs/
examples/
moto-init/
scripts/
site/
skills/
tests/
# Judy is an independent Rust project and is never part of Praxis's Go image.
judy/
.DS_Store
**/.DS_Store
# Coverage profiles (written by `just test`) change on every run; if included
# they invalidate the COPY layer and force a full rebuild of all binaries.
*.out
