# Praxis stack
PRAXIS_LISTEN_ADDR=0.0.0.0:9080
PRAXIS_RESTATE_ENDPOINT=http://restate:8080
PRAXIS_SCHEMA_DIR=/schemas

# Operator-defined AWS account
PRAXIS_ACCOUNT_NAME=local
PRAXIS_ACCOUNT_REGION=us-east-1
PRAXIS_ACCOUNT_CREDENTIAL_SOURCE=static

# Static credentials for LocalStack or other development environments
PRAXIS_ACCOUNT_ACCESS_KEY_ID=test
PRAXIS_ACCOUNT_SECRET_ACCESS_KEY=test

# Role-based configuration for production (for initial boot and fallback)
# PRAXIS_ACCOUNT_CREDENTIAL_SOURCE=role
# PRAXIS_ACCOUNT_ROLE_ARN=arn:aws:iam::123456789012:role/PraxisDriverRole
# PRAXIS_ACCOUNT_EXTERNAL_ID=praxis-prod

# Default SDK chain configuration (IMDS, ECS task role, shared config)
# PRAXIS_ACCOUNT_CREDENTIAL_SOURCE=default

# Optional endpoint override for LocalStack
AWS_ENDPOINT_URL=http://localstack:4566